/* ---------- Chart.js defaults ---------- */
Chart.defaults.font.family = "'Inter',sans-serif";
Chart.defaults.color = '#5C6B70';
Chart.defaults.font.size = 11;

const zonas3 = ['Norte','Centro','Sur'];
const cfgs = ['RF_1_conservador','RF_2_intermedio','RF_3_profundo'];
const cfgColors = ['#B9C7C4','#5FA8B8','#123049'];

function seriesFor(metric){
  return cfgs.map((cfg,i)=>({
    label: cfg,
    backgroundColor: cfgColors[i],
    data: zonas3.map(z => modelos.find(m=>m.zona===z && m.modelo===cfg)[metric])
  }));
}

new Chart(document.getElementById('chartRmse'), {
