/* ---------- Leaflet map ---------- */
(function(){
  const map = L.map('map', {scrollWheelZoom:false}).setView([-10, -79], 5);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution:'&copy; OpenStreetMap contributors', maxZoom: 9
  }).addTo(map);

  const zones = [
    {name:'Norte',  color:'#DD5A36', bounds:[[0,-85],[-6,-75]]},
    {name:'Centro', color:'#1C7C93', bounds:[[-6,-85],[-13,-75]]},
    {name:'Sur',    color:'#123049', bounds:[[-13,-85],[-20,-75]]},
  ];
  zones.forEach(z=>{
    L.rectangle(z.bounds, {color:z.color, weight:1.5, fillOpacity:0.18})
      .addTo(map)
      .bindPopup(`<strong>Zona ${z.name}</strong><br>Promedio espacial de SST NOAA OISST usado como serie de la zona.`);
  });

  const refs = [
    {name:'Tumbes', lat:-3.57, lon:-80.45},
    {name:'Lima', lat:-12.05, lon:-77.03},
    {name:'Ica', lat:-14.07, lon:-75.73},
  ];
  refs.forEach(r=>{
    L.circleMarker([r.lat, r.lon], {radius:4, color:'#0B1F2A', fillColor:'#fff', fillOpacity:1, weight:1.5})
      .addTo(map).bindTooltip(r.name, {permanent:false});
  });
})();

/* ---------- Scroll spy for sidenav ---------- */
(function(){
  const links = document.querySelectorAll('#sidenav a');
  const sections = Array.from(links).map(a=>document.querySelector(a.getAttribute('href')));
  window.addEventListener('scroll', ()=>{
    let idx = 0;
    sections.forEach((s,i)=>{ if(s && window.scrollY >= s.offsetTop - 120) idx = i; });
    links.forEach((a,i)=>a.classList.toggle('active', i===idx));
  });
})();
</script>
