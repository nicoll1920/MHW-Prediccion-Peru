    responsive:true,
    plugins:{legend:{position:'bottom',labels:{boxWidth:10,font:{size:10}}}},
    scales:{y:{title:{display:true,text:'RMSE SST (°C)'}}}
  }
});

new Chart(document.getElementById('chartR2'), {
  type:'bar',
  data:{labels:zonas3, datasets:seriesFor('r2')},
  options:{
    responsive:true,
    plugins:{legend:{position:'bottom',labels:{boxWidth:10,font:{size:10}}}},
